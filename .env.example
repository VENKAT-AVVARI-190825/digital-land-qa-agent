# Required for live LLM calls. Leave unset to run in mock mode (deterministic stubs).
ANTHROPIC_API_KEY=

# Optional: override the model. Default is claude-opus-4-7.
DL_QA_MODEL=claude-opus-4-7

# Optional: cap total tokens spent across one agent run.
DL_QA_TASK_BUDGET_TOKENS=200000

# Optional: where to write per-run artifacts and audit logs.
DL_QA_RUNS_DIR=./runs
